# Enforce LF line endings for all auto-detected text files.
# Prevents CRLF from creeping back in on Windows/WSL checkouts.
* text=auto eol=lf

# Treat known binary assets as binary so they are never line-ending normalized.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.jfif  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
